{
  "name": "@qute/core",
  "version": "0.0.1",
  "type": "module",
  "main": "./qute.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./qute.js",
      "types": "./src/index.ts"
    }
  },
  "engines": {
    "node": ">=23.0.0"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=esm --sourcemap --minify --outfile=../../qute.js",
    "dev": "esbuild src/index.ts --bundle --format=esm --sourcemap --outfile=qute.js --watch"
  },
  "devDependencies": {
    "esbuild": "catalog:"
  }
}
