{
  "name": "@erikt/ajax",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=23.0.0"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=esm --sourcemap --minify --outfile=dist/index.js --external:idiomorph && tsc --emitDeclarationOnly --declarationDir dist",
    "dev": "mkdir -p dist && esbuild src/index.ts --bundle --format=esm --sourcemap --outfile=dist/index.js --external:idiomorph --watch"
  },
  "peerDependencies": {
    "idiomorph": "^0.7.4"
  },
  "peerDependenciesMeta": {
    "idiomorph": {
      "optional": true
    }
  },
  "devDependencies": {
    "esbuild": "catalog:",
    "idiomorph": "^0.7.4",
    "typescript": "catalog:"
  }
}
