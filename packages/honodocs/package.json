{
  "name": "honodocs",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "bin": {
    "honodocs": "./src/bin.ts"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist && esbuild src/index.ts --bundle --format=esm --sourcemap --minify --outfile=dist/index.js --external:hono --external:marked",
    "dev": "esbuild src/index.ts --bundle --format=esm --sourcemap --outfile=dist/index.js --external:hono --external:marked --watch"
  },
  "dependencies": {
    "hono": "catalog:",
    "marked": "^18.0.4"
  },
  "devDependencies": {
    "esbuild": "catalog:"
  }
}
