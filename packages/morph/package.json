{
  "name": "@qute/morph",
  "version": "0.0.1-beta.1",
  "type": "module",
  "main": "./morph.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./morph.js",
      "types": "./src/index.ts"
    }
  },
  "engines": {
    "node": ">=23.0.0"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=esm --sourcemap --minify --outfile=../../morph.js --external:@qute/core --external:idiomorph",
    "dev": "esbuild src/index.ts --bundle --format=esm --sourcemap --outfile=../../morph.js --external:@qute/core --external:idiomorph --watch"
  },
  "peerDependencies": {
    "@qute/core": "workspace:*",
    "idiomorph": "^0.7.4"
  },
  "devDependencies": {
    "@qute/core": "workspace:*",
    "esbuild": "catalog:"
  }
}
