{
  "name": "@qute/preload",
  "version": "0.0.1-beta.2",
  "type": "module",
  "main": "./preload.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./preload.js",
      "types": "./src/index.ts"
    }
  },
  "engines": {
    "node": ">=23.0.0"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=esm --sourcemap --minify --outfile=../../preload.js --external:@qute/core",
    "dev": "esbuild src/index.ts --bundle --format=esm --sourcemap --outfile=../../preload.js --external:@qute/core --watch"
  },
  "peerDependencies": {
    "@qute/core": "workspace:*"
  },
  "devDependencies": {
    "@qute/core": "workspace:*",
    "esbuild": "catalog:"
  }
}
